generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// no native enums on sqlite - role/status fields are strings, validated in the zod schemas
// Expense.type: TOLL | MAINTENANCE | OTHER

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
}

model Vehicle {
  id                 String   @id @default(cuid())
  registrationNumber String   @unique
  name               String
  type               String
  maxLoadCapacity    Float
  odometer           Float    @default(0)
  acquisitionCost    Float
  region             String   @default("Unassigned")
  documentUrl        String?
  status             String   @default("AVAILABLE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  trips       Trip[]
  maintenance MaintenanceLog[]
  fuelLogs    FuelLog[]
  expenses    Expense[]
}

model Driver {
  id              String   @id @default(cuid())
  name            String
  licenseNumber   String   @unique
  licenseCategory String
  licenseExpiry   DateTime
  contactNumber   String
  safetyScore     Float    @default(100)
  status          String   @default("AVAILABLE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trips Trip[]
}

model Trip {
  id              String    @id @default(cuid())
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance Float
  actualDistance  Float?
  fuelConsumed    Float?
  revenue         Float     @default(0)
  status          String    @default("DRAFT")
  vehicleId       String
  driverId        String
  createdAt       DateTime  @default(now())
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  driver   Driver    @relation(fields: [driverId], references: [id])
  fuelLogs FuelLog[]
}

model MaintenanceLog {
  id          String    @id @default(cuid())
  vehicleId   String
  description String
  cost        Float
  date        DateTime  @default(now())
  status      String    @default("OPEN")
  createdAt   DateTime  @default(now())
  closedAt    DateTime?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  tripId    String?
  liters    Float
  cost      Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?    @relation(fields: [tripId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  vehicleId   String
  type        String
  amount      Float
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
}
